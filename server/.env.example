# ============================================================
# GeologyGPT v3 — Agentic RAG Environment Variables
# ============================================================

# --- Google Gemini (FREE at ai.google.dev) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenAI (embeddings only, ~$0.02/1M tokens) ---
# OR set USE_GEMINI_EMBEDDINGS=true to skip this
OPENAI_API_KEY=your_openai_api_key_here

# --- Pinecone (free tier at pinecone.io) ---
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=geologygpt

# --- Web Search (pick ONE — both optional, agent works without them) ---
# Tavily: free tier at tavily.com (recommended, geology-aware)
TAVILY_API_KEY=your_tavily_api_key_here
# SerpAPI: fallback at serpapi.com
# SERPAPI_KEY=your_serpapi_key_here

# --- Embedding config ---
USE_GEMINI_EMBEDDINGS=false

# --- Server ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
