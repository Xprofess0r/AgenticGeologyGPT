# ============================================================
# GeologyGPT Python Agent — Environment Variables
# Copy this file to .env and fill in your keys
# ============================================================

# --- Google Gemini (https://ai.google.dev — FREE tier) ---
# Free tier: 15 RPM, 1M TPM on gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here

# --- Cohere (embeddings — https://cohere.com) ---
# Free tier: 100 calls/min
# NOTE: This project uses cohere v5 — uses ClientV2 API
COHERE_API_KEY=your_cohere_api_key_here

# --- Pinecone (https://pinecone.io — FREE tier available) ---
# NOTE: Install 'pinecone' package, NOT 'pinecone-client'
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=geologygpt

# --- Tavily Web Search (https://tavily.com — optional) ---
# Free tier: 1000 searches/month
# If not set, web search is silently skipped — RAG still works
TAVILY_API_KEY=your_tavily_api_key_here

# --- Python agent port ---
PYTHON_AGENT_PORT=8000
